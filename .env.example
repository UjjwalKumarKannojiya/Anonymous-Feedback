# MongoDB Connection String
# Get this from MongoDB Atlas: https://www.mongodb.com/cloud
MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/mstrymessage?retryWrites=true&w=majority"

# NextAuth Configuration
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-generated-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Resend Email Service
# Get from: https://resend.com
RESEND_API_KEY="re_your_api_key_here"

# OpenAI API Key (Optional - for message suggestions)
# Get from: https://platform.openai.com
OPENAI_API_KEY="sk-your_api_key_here"

# Environment
NODE_ENV="development"
